# BhashaBridge AI — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
# Copy to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════════

# Sarvam AI API Key (required)
# Get yours at: https://dashboard.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here

# Application Settings
DEBUG=false
HOST=0.0.0.0
PORT=8000
